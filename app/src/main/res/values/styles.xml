<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="game_theme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/game_bg_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="colorPrimary">@color/game_orange</item>
        <item name="colorAccent">@color/game_orange</item>
    </style>

    <style name="game_space_full_screen" parent="game_theme">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <style name="game_space_splash" parent="game_space_full_screen">
        <item name="android:windowBackground">@color/game_bg_dark</item>
    </style>

    <style name="game_open_jump" parent="game_theme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>

</resources>
