<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_add_collection.xml
    Écran "Ajouter une collection" — import depuis un fichier metadata Pegasus.
    Style gaming sombre cohérent avec l'app Vivo Game Space.
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A1A">

    <!-- Fond décoratif -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/game_space_main_page_defaultbg"
        android:scaleType="centerCrop"
        android:alpha="0.4" />

    <!-- ─── Barre de titre ──────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#88000000">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/game_space_ic_back"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/gs_add_collection"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- ─── Contenu centré ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/bg_collection_panel">

        <!-- Icône Pegasus / Collection -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_add_collection"
            android:scaleType="centerInside"
            android:alpha="0.9" />

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/gs_collection_pegasus_title"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Description -->
        <TextView
            android:id="@+id/tv_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/gs_collection_pegasus_hint"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4" />

        <!-- Chemin du fichier sélectionné -->
        <TextView
            android:id="@+id/tv_file_path"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="10dp"
            android:background="@drawable/bg_search_bar"
            android:text="@string/gs_collection_no_file"
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="start"
            android:gravity="center" />

        <!-- Bouton Choisir un fichier -->
        <RelativeLayout
            android:id="@+id/btn_choose_file"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_add_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/gs_collection_choose_file"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Bouton Importer -->
        <RelativeLayout
            android:id="@+id/btn_import"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_add_button_secondary"
            android:clickable="true"
            android:focusable="true"
            android:enabled="false"
            android:alpha="0.5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/gs_collection_import"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />
        </RelativeLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <!-- Status / resultat : icone SVG + texte -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_status_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:visibility="gone"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#FFFFFFFF"
                android:gravity="center_vertical"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
